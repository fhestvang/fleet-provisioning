[Unit]
Description=GitHub Actions runner for fhestvang/fos-zennotes on Spark
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/fhestvang/actions-runner/fos-zennotes
ExecStart=/home/fhestvang/actions-runner/fos-zennotes/run.sh
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=default.target
