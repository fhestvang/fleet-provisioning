[Unit]
Description=GitHub Actions CI runner for fhestvang/fos on Spark
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/fhestvang/actions-runner/fos-ci
ExecStart=/home/fhestvang/actions-runner/fos-ci/run.sh
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=default.target
