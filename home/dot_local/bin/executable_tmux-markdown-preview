#!/usr/bin/env bash
set -euo pipefail

file="$(
  find . -type f \( -iname '*.md' -o -iname '*.markdown' \) 2>/dev/null |
    fzf \
      --prompt='Markdown > ' \
      --preview='glow --style dark {}' \
      --preview-window='right:62%:wrap'
)"

[ -n "$file" ] || exit 0
"$HOME/.local/bin/markdown-preview-browser" "$file"
