#!/bin/sh
# Mirrors coding-agent activity (Claude Code, Codex, ...) into the tmux status
# bar via tmux-agent-state. Renders: working (*), done (!), blocked/help (?).
#
# Chezmoi source: fleet-provisioning/home/dot_local/bin/executable_tmux-agent-status.
# Live path: ~/.local/bin/tmux-agent-status.
# Invoked from each runtime's hook config with a single action argument:
#   tmux-agent-status working   # a turn / tool call is starting
#   tmux-agent-status idle       # a turn ended (classified into done/blocked)
# JSON hook payload is read from stdin when available.

set -eu

action="${1:-}"
payload="$(cat 2>/dev/null || true)"

case "$action" in
  working|idle|blocked|question|notify|release) ;;
  *) exit 0 ;;
esac

if command -v python3 >/dev/null 2>&1; then
  mapped="$(
    printf '%s' "$payload" | TMUX_AGENT_ACTION="$action" python3 -c '
import json
import os
import sys

action = os.environ.get("TMUX_AGENT_ACTION", "")
raw = sys.stdin.read()
data = {}

try:
    if raw.strip():
        parsed = json.loads(raw)
        if isinstance(parsed, dict):
            data = parsed
except Exception:
    data = {}

def first_string(*keys):
    for key in keys:
        value = data.get(key)
        if isinstance(value, str):
            return value
    return ""

event = first_string(
    "hook_event_name",
    "hookEventName",
    "hook_event",
    "hookEvent",
    "event",
    "event_name",
)
prompt = first_string("prompt", "user_prompt", "message", "input").strip().lower()
source = first_string("source").strip().lower()
event_key = event.replace("_", "").replace("-", "").lower()

if action == "idle" and (event_key == "sessionstart" or source == "clear"):
    action = "release"
elif action == "working" and prompt in {"clear", "/clear", "clear session", "/clear session"}:
    action = "release"

# The notify action is the Claude Notification entry point. That event fires for
# BOTH a genuine permission or approval prompt AND the passive waiting-for-input
# idle nudge. Mapping the nudge to a block would light up every finished session.
# So promote notify to a real block only on a permission-ish message; anything
# else, including an empty payload, becomes noop and leaves the existing glyph
# untouched. Codex sends question directly and always blocks.
if action == "notify":
    message = first_string("message", "body", "notification", "text").lower()
    if any(k in message for k in (
        "permission", "approve", "approval", "needs your", "grant", "allow",
    )):
        action = "question"
    else:
        action = "noop"

# When a turn ends (idle == Stop) surface the transcript path so the caller can
# classify whether the agent finished (done) or left a question (blocked).
transcript = first_string("transcript_path", "transcriptPath", "transcript") if action == "idle" else ""

print(action)
print(transcript)
'
  )" || mapped="$action"
  mapped_action="$(printf '%s\n' "$mapped" | head -n 1)"
  transcript="$(printf '%s\n' "$mapped" | sed -n '2p')"
  case "$mapped_action" in
    working|idle|blocked|question|noop|release) action="$mapped_action" ;;
  esac

  # A filtered-out Notification (idle nudge, not a real block) leaves state as-is.
  [ "$action" = noop ] && exit 0

  # On turn end, ask the classifier whether the agent is waiting on the user;
  # if so switch to "blocked" (rendered as "?" in the tmux status bar).
  if [ "$action" = idle ] && [ -n "$transcript" ]; then
    decision=""
    if command -v tmux-agent-classify >/dev/null 2>&1; then
      decision="$(tmux-agent-classify "$transcript" 2>/dev/null || true)"
    elif [ -x "$HOME/.local/bin/tmux-agent-classify" ]; then
      decision="$("$HOME/.local/bin/tmux-agent-classify" "$transcript" 2>/dev/null || true)"
    fi
    [ "$decision" = blocked ] && action=blocked
  fi
fi

if [ -n "${TMUX:-}" ]; then
  if command -v tmux-agent-state >/dev/null 2>&1; then
    tmux-agent-state "$action" >/dev/null 2>&1 || true
  elif [ -x "$HOME/.local/bin/tmux-agent-state" ]; then
    "$HOME/.local/bin/tmux-agent-state" "$action" >/dev/null 2>&1 || true
  fi
fi

exit 0
