#!/usr/bin/env bash
set -euo pipefail

tmp="$(mktemp "${TMPDIR:-/tmp}/clipboard-copy.XXXXXX")"
cleanup() {
  rm -f "$tmp"
}
trap cleanup EXIT

cat >"$tmp"

is_wsl() {
  grep -qiE '(microsoft|wsl)' /proc/sys/kernel/osrelease 2>/dev/null
}

copy_with() {
  "$@" <"$tmp"
}

copy_with_osc52() {
  command -v base64 >/dev/null 2>&1 || return 1

  local encoded sequence tty_path
  encoded="$(base64 <"$tmp" | tr -d '\r\n')"
  [ -n "$encoded" ] || return 1
  sequence="$(printf '\033]52;c;%s\a' "$encoded")"

  if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
    tty_path="$(tmux display-message -p '#{client_tty}' 2>/dev/null || true)"
    if [ -n "$tty_path" ] && [ -w "$tty_path" ]; then
      printf '%s' "$sequence" >"$tty_path"
      return 0
    fi
  fi

  if [ -t 1 ]; then
    printf '%s' "$sequence"
    return 0
  fi

  tty_path="$(tty 2>/dev/null || true)"
  if [ -n "$tty_path" ] && [ "$tty_path" != "not a tty" ] && [ -w "$tty_path" ]; then
    printf '%s' "$sequence" >"$tty_path"
    return 0
  fi

  return 1
}

if is_wsl && command -v clip.exe >/dev/null 2>&1; then
  copy_with clip.exe
elif is_wsl && [ -x /mnt/c/Windows/System32/clip.exe ]; then
  copy_with /mnt/c/Windows/System32/clip.exe
elif command -v wl-copy >/dev/null 2>&1; then
  copy_with wl-copy
elif command -v xclip >/dev/null 2>&1; then
  copy_with xclip -selection clipboard
elif command -v xsel >/dev/null 2>&1; then
  copy_with xsel --clipboard --input
elif command -v pbcopy >/dev/null 2>&1; then
  copy_with pbcopy
elif command -v clip.exe >/dev/null 2>&1; then
  copy_with clip.exe
elif copy_with_osc52; then
  exit 0
else
  exit 0
fi
