#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  printf 'usage: markdown-preview-browser <file.md>\n' >&2
  exit 2
fi

src="$(realpath "$1")"
if [ ! -f "$src" ]; then
  printf 'markdown-preview-browser: not a file: %s\n' "$src" >&2
  exit 1
fi

cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/markdown-preview"
site_dir="$cache_root/site"

mkdir -p "$site_dir"

hash="$(printf '%s' "$src" | sha256sum | awk '{ print $1 }')"
out="$site_dir/${hash}.html"

python3 - "$src" "$out" <<'PY'
import html
import json
import pathlib
import sys

src = pathlib.Path(sys.argv[1])
out = pathlib.Path(sys.argv[2])
markdown = src.read_text(encoding="utf-8", errors="replace")
title = src.name
markdown_json = json.dumps(markdown).replace("</", "<\\/")

document = f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{html.escape(title)}</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css@5/github-markdown.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11/styles/github-dark-dimmed.min.css">
  <style>
    :root {{
      color-scheme: light dark;
      --bg: #0f1117;
      --panel: #151923;
      --text: #dbe2f2;
      --muted: #8e99ad;
      --border: #2c3444;
      --accent: #7aa2f7;
    }}
    @media (prefers-color-scheme: light) {{
      :root {{
        --bg: #f6f7fb;
        --panel: #ffffff;
        --text: #182033;
        --muted: #667085;
        --border: #d9deea;
        --accent: #2457d6;
      }}
    }}
    body {{
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font: 16px/1.6 ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }}
    header {{
      position: sticky;
      top: 0;
      z-index: 2;
      border-bottom: 1px solid var(--border);
      background: color-mix(in srgb, var(--bg) 88%, transparent);
      backdrop-filter: blur(14px);
    }}
    .bar {{
      max-width: 1040px;
      margin: 0 auto;
      padding: 14px 28px;
      display: flex;
      gap: 16px;
      align-items: baseline;
      justify-content: space-between;
    }}
    .title {{
      font-weight: 700;
      letter-spacing: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    .path {{
      color: var(--muted);
      font-size: 13px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }}
    main {{
      max-width: 1040px;
      margin: 0 auto;
      padding: 28px;
    }}
    .markdown-body {{
      box-sizing: border-box;
      min-width: 200px;
      max-width: 980px;
      margin: 0 auto 48px;
      padding: 42px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--panel);
      color: var(--text);
      box-shadow: 0 18px 48px rgba(0, 0, 0, .20);
    }}
    .markdown-body h1, .markdown-body h2 {{
      border-bottom-color: var(--border);
    }}
    .markdown-body pre {{
      border: 1px solid var(--border);
    }}
    .markdown-body a {{
      color: var(--accent);
    }}
    @media (max-width: 760px) {{
      .bar {{ padding: 12px 16px; display: block; }}
      main {{ padding: 0; }}
      .markdown-body {{
        border-left: 0;
        border-right: 0;
        border-radius: 0;
        padding: 24px 18px;
      }}
    }}
  </style>
</head>
<body>
  <header>
    <div class="bar">
      <div class="title">{html.escape(title)}</div>
      <div class="path">{html.escape(str(src))}</div>
    </div>
  </header>
  <main>
    <article id="content" class="markdown-body"></article>
  </main>
  <script type="application/json" id="markdown-source">{markdown_json}</script>
  <script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/highlight.js@11/highlight.min.js"></script>
  <script>
    const raw = JSON.parse(document.getElementById("markdown-source").textContent);
    marked.setOptions({{ gfm: true, breaks: false }});
    document.getElementById("content").innerHTML = DOMPurify.sanitize(marked.parse(raw));
    document.querySelectorAll("pre code").forEach((block) => hljs.highlightElement(block));
  </script>
</body>
</html>
"""
out.write_text(document, encoding="utf-8")
PY

ssh -o BatchMode=yes laptop \
  'cmd /c if not exist "%LOCALAPPDATA%\SparkOpenUrl\preview" mkdir "%LOCALAPPDATA%\SparkOpenUrl\preview"' >/dev/null
scp -q -o BatchMode=yes "$out" "laptop:AppData/Local/SparkOpenUrl/preview/$(basename "$out")"

remote_appdata="$(
  ssh -o BatchMode=yes laptop 'cmd /c echo %LOCALAPPDATA%' | tr -d '\r' | sed 's/^"//; s/"$//'
)"
url="$(
  python3 - "$remote_appdata" "$(basename "$out")" <<'PY'
import sys
from urllib.parse import quote

path = sys.argv[1].rstrip("\\/") + "\\SparkOpenUrl\\preview\\" + sys.argv[2]
path = path.replace("\\", "/")
print("file:///" + quote(path, safe="/:"))
PY
)"
OPEN_ON_LAPTOP_METHOD=direct "$HOME/.local/bin/open-on-laptop" "$url"
printf '%s\n' "$url"
