#!/usr/bin/env python3
"""Classify how an agent turn ended, for the tmux status indicator.

Given a transcript path (a JSONL file, or a directory whose newest *.jsonl is
used), inspect the LAST assistant message and decide:

    blocked  -> the agent ended by asking the user / needs help  (renders "?")
    done     -> the agent finished normally                       (renders "!")

A turn is "blocked" ONLY when the last assistant message invokes a tool that, by
definition, waits for the user -- e.g. Claude Code's ExitPlanMode (plan approval)
or AskUserQuestion. That is a structural, unambiguous signal. (Codex/pi don't
emit these tools, so the check is simply inert there.)

We deliberately do NOT treat "the message ends with a question mark" as blocked:
agents routinely finish the work and sign off with an optional follow-up offer
("want me to also...?"), which is *done*, not stuck. A real blocking question and
a polite closing question are textually indistinguishable, so that heuristic only
produced false "?"s on finished sessions.

Anything else, or anything unparseable, is "done" so the indicator never gets
stuck on "?". The live "needs-you" moments that happen mid-turn (tool-permission
/ approval prompts) are surfaced by each runtime's own hooks (Claude
Notification, Codex PermissionRequest), not here.

Handles two transcript shapes:
  - Claude Code / pi.dev : {"type": "assistant"|"message",
                            "message": {"role": "assistant",
                                        "content": [{"type": "text", ...},
                                                    {"type": "tool_use", ...}]}}
  - Codex                : {"payload": {"type": "agent_message"|"message", ...}}
"""

import glob
import json
import os
import sys


# Tool names whose presence in the final assistant message mean "waiting on the
# user". Compared after stripping to alphanumerics, case-insensitively.
BLOCKING_TOOLS = {"exitplanmode", "askuserquestion"}


def newest_jsonl(directory):
    files = glob.glob(os.path.join(directory, "**", "*.jsonl"), recursive=True)
    if not files:
        return None
    return max(files, key=os.path.getmtime)


def _norm(name):
    return "".join(ch for ch in name.lower() if ch.isalnum())


def extract_text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for block in content:
            if isinstance(block, dict) and block.get("type") in ("text", "output_text"):
                text = block.get("text")
                if isinstance(text, str):
                    parts.append(text)
        return "".join(parts)
    return ""


def has_blocking_tool(content):
    if not isinstance(content, list):
        return False
    for block in content:
        if not isinstance(block, dict):
            continue
        if block.get("type") in ("tool_use", "tool_call", "function_call"):
            name = block.get("name")
            if isinstance(name, str) and _norm(name) in BLOCKING_TOOLS:
                return True
    return False


def last_assistant(path):
    """Return (text, blocked_by_tool) for the newest assistant message."""
    last_text = ""
    last_block = False
    try:
        with open(path, "r", errors="ignore") as handle:
            for line in handle:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                if not isinstance(obj, dict):
                    continue

                # Codex rollout format.
                payload = obj.get("payload")
                if isinstance(payload, dict):
                    ptype = payload.get("type")
                    if ptype == "agent_message":
                        text = payload.get("message") or payload.get("text") or ""
                        if isinstance(text, str) and text.strip():
                            last_text, last_block = text, False
                    elif ptype == "message" and payload.get("role") == "assistant":
                        content = payload.get("content")
                        text = extract_text(content)
                        block = has_blocking_tool(content)
                        if text.strip() or block:
                            last_text, last_block = text, block
                    continue

                # Claude Code / pi.dev format.
                message = obj.get("message")
                is_assistant = (
                    isinstance(message, dict) and message.get("role") == "assistant"
                ) or (obj.get("type") == "assistant" and isinstance(message, dict))
                if is_assistant:
                    content = message.get("content")
                    text = extract_text(content)
                    block = has_blocking_tool(content)
                    if text.strip() or block:
                        last_text, last_block = text, block
    except Exception:
        return ("", False)
    return (last_text, last_block)


def main():
    if len(sys.argv) < 2 or not sys.argv[1]:
        print("done")
        return
    arg = sys.argv[1]
    path = newest_jsonl(arg) if os.path.isdir(arg) else arg
    if not path or not os.path.isfile(path):
        print("done")
        return
    _, blocked_tool = last_assistant(path)
    print("blocked" if blocked_tool else "done")


if __name__ == "__main__":
    main()
