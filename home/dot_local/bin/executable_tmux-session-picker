#!/usr/bin/env sh
set -eu

if ! command -v tmux >/dev/null 2>&1; then
  printf '%s\n' 'tmux-session-picker: tmux not found' >&2
  exit 1
fi

# Plain sessions only — no per-tty grouped sessions. Grouping let sibling
# sessions diverge on current-window, which (with focus-events) made Win+Shift+S
# screenshot the wrong window. Attaches without exec so detaching returns to the
# calling shell rather than closing the connection.

# Inside tmux: fzf popup to switch between existing sessions.
if [ -n "${TMUX:-}" ]; then
  if command -v fzf >/dev/null 2>&1; then
    tmux display-popup -E -w 88% -h 78% -d "#{pane_current_path}" -T "tmux sessions" \
      'session="$(tmux list-sessions -F "#{session_name}" | fzf --prompt="tmux session> " --height=100% --layout=reverse --border=none)" || exit; [ -n "$session" ] || exit; tmux switch-client -t "$session"'
  else
    tmux display-message 'tmux-session-picker: install fzf for session switching'
  fi
  exit 0
fi

# Outside tmux: pick an existing session and attach, or create `main`.
if tmux has-session >/dev/null 2>&1; then
  if command -v fzf >/dev/null 2>&1; then
    session="$(tmux list-sessions -F '#{session_name}' | fzf --prompt='tmux session> ' --height=100% --layout=reverse --border=none || true)"
  else
    session="$(tmux list-sessions -F '#{session_name}' | sed -n '1p')"
  fi
  [ -n "$session" ] || exit 0
  tmux -2 attach-session -t "$session"
  exit 0
fi

tmux -2 new-session -A -s main
