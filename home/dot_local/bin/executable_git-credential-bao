#!/usr/bin/env sh
# git credential helper backed by OpenBao.
#
# Serves the fleet GitHub token from kv/projects/fos/shared/github-cli so any
# git operation against github.com authenticates without `gh auth login`. This
# is the same token+path the toolkit-sync askpass uses; here it's exposed to
# *all* git operations via the standard credential-helper protocol.
#
# Wired in dot_gitconfig as the primary helper for github.com, with
# `!gh auth git-credential` kept as the fallback. This helper deliberately
# stays silent (exit 0, no output) whenever it can't serve a token -- wrong
# host, no bao CLI, bao unreachable, dead token, empty value -- so git falls
# through to the next helper instead of failing. Holds no secrets itself.
set -eu

# git calls helpers with get/store/erase. We only answer reads; store/erase
# are no-ops (bao is the source of truth, nothing to cache or forget locally).
[ "${1:-}" = "get" ] || exit 0

host=""
while IFS= read -r line; do
  [ -z "$line" ] && break
  case "$line" in
    host=*) host=${line#host=} ;;
  esac
done

case "$host" in
  github.com | gist.github.com) ;;
  *) exit 0 ;;
esac

command -v bao >/dev/null 2>&1 || exit 0
: "${BAO_ADDR:=https://bao.olm-hops.ts.net}"
export BAO_ADDR

token=$(bao kv get -field=GITHUB_TOKEN kv/projects/fos/shared/github-cli 2>/dev/null) || exit 0
[ -n "$token" ] || exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n' "$token"
