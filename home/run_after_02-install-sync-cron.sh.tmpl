#!/usr/bin/env bash
# Ensure the hourly convergence cron calls chezmoi-sync (non-interactive,
# self-healing config, failure-notifying) instead of a bare `chezmoi update`.
# Idempotent: rewrites only our convergence line, preserving every other job.
#   {{ .hostname }}
set -euo pipefail

bin="$HOME/.local/bin/chezmoi-sync"
marker="# fleet chezmoi convergence"
line="@hourly $bin"

current="$(crontab -l 2>/dev/null || true)"

# Strip any prior convergence entries: our marker, our bin path, and the legacy
# `chezmoi update` form this replaces. Everything else is kept verbatim.
cleaned="$(printf '%s\n' "$current" \
  | grep -vF "$marker" \
  | grep -vF "$bin" \
  | grep -vF 'chezmoi update' \
  || true)"

{
  [ -n "$cleaned" ] && printf '%s\n' "$cleaned"
  printf '%s\n%s\n' "$marker" "$line"
} | crontab -

echo "cron: ensured hourly chezmoi-sync"
