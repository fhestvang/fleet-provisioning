[Unit]
Description=GitHub Actions runner for fhestvang/fos on Spark
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/fhestvang/actions-runner/fos
ExecStart=/home/fhestvang/actions-runner/fos/run.sh
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=30
Environment=FOS_ORCH_RUNNER_USER=fhestvang

[Install]
WantedBy=default.target
